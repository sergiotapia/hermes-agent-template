+@pytest.mark.asyncio
+async def test_session_chat_calls_auto_title_after_successful_turn(auth_adapter, session_db):
+    session_id = session_db.create_session("chat-title-session", "api_server")
+    turn_messages = [
+        {"role": "user", "content": "next"},
+        {"role": "assistant", "content": "fresh answer"},
+    ]
+    mock_run = AsyncMock(
+        return_value=(
+            {"final_response": "fresh answer", "session_id": session_id, "messages": turn_messages},
+            {"total_tokens": 3},
+        )
+    )
+
+    app = _create_session_app(auth_adapter)
+    with (
+        patch.object(auth_adapter, "_run_agent", mock_run),
+        patch.object(auth_adapter, "_title_generation_main_runtime", return_value={"model": "test-model"}),
+        patch("agent.title_generator.maybe_auto_title") as mock_title,
+    ):
+        async with TestClient(TestServer(app)) as cli:
+            resp = await cli.post(
+                f"/api/sessions/{session_id}/chat",
+                json={"message": "next"},
+                headers={"Authorization": "Bearer sk-test"},
+            )
+            assert resp.status == 200
+
+    mock_title.assert_called_once()
+    args, kwargs = mock_title.call_args
+    assert args[:5] == (session_db, session_id, "next", "fresh answer", turn_messages)
+    assert kwargs["main_runtime"] == {"model": "test-model"}
+    assert callable(kwargs["failure_callback"])
+
