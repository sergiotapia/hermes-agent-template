+@pytest.mark.asyncio
+async def test_session_chat_stream_emits_structured_tool_result(adapter, session_db):
+    session_id = session_db.create_session("stream-tool-session", "api_server")
+
+    async def fake_run(**kwargs):
+        kwargs["tool_start_callback"]("call_1", "nabi_care_next_appointment", {})
+        kwargs["tool_complete_callback"](
+            "call_1",
+            "nabi_care_next_appointment",
+            {},
+            '{"ok":true,"artifacts":[{"type":"appointment.card","version":1}]}',
+        )
+        kwargs["stream_delta_callback"]("Your next appointment is tomorrow.")
+        return {
+            "final_response": "Your next appointment is tomorrow.",
+            "session_id": session_id,
+        }, {"total_tokens": 6}
+
+    app = _create_session_app(adapter)
+    with patch.object(adapter, "_run_agent", side_effect=fake_run):
+        async with TestClient(TestServer(app)) as cli:
+            resp = await cli.post(
+                f"/api/sessions/{session_id}/chat/stream",
+                json={"message": "When is my next appointment?"},
+            )
+            assert resp.status == 200
+            body = await resp.text()
+
+    assert "event: tool.started" in body
+    assert "event: tool.completed" in body
+    assert '"tool_call_id": "call_1"' in body
+    assert '"tool_name": "nabi_care_next_appointment"' in body
+    assert '"appointment.card"' in body
+
+
+@pytest.mark.asyncio
+async def test_session_chat_stream_calls_auto_title_after_successful_turn(adapter, session_db):
+    session_id = session_db.create_session("stream-title-session", "api_server")
+    turn_messages = [
+        {"role": "user", "content": "stream please"},
+        {"role": "assistant", "content": "Hello world"},
+    ]
+
+    async def fake_run(**kwargs):
+        kwargs["stream_delta_callback"]("Hello world")
+        return {
+            "final_response": "Hello world",
+            "session_id": session_id,
+            "messages": turn_messages,
+        }, {"total_tokens": 2}
+
+    app = _create_session_app(adapter)
+    with (
+        patch.object(adapter, "_run_agent", side_effect=fake_run),
+        patch.object(adapter, "_title_generation_main_runtime", return_value={"model": "test-model"}),
+        patch("agent.title_generator.maybe_auto_title") as mock_title,
+    ):
+        async with TestClient(TestServer(app)) as cli:
+            resp = await cli.post(
+                f"/api/sessions/{session_id}/chat/stream",
+                json={"message": "stream please"},
+            )
+            assert resp.status == 200
+            await resp.text()
+
+    mock_title.assert_called_once()
+    args, kwargs = mock_title.call_args
+    assert args[:5] == (session_db, session_id, "stream please", "Hello world", turn_messages)
+    assert kwargs["main_runtime"] == {"model": "test-model"}
+    assert callable(kwargs["failure_callback"])
+
